#!/usr/bin/env python3
"""hamtag - Generate ZPL name badge labels for Zebra thermal printers.

Looks up HAM callsigns in a hamdat SQLite database and produces ZPL
ready to send to a Zebra thermal label printer.

Label format: 4"x6" stock rendered as a single PIL bitmap, rotated 90°
clockwise for landscape orientation (6" wide, 4" tall when worn).
The same PIL image is used for both the print output and the GUI preview.

Author: Matt Hoskins, K2TTA
"""

import argparse
import os
import sqlite3
import sys
from pathlib import Path

try:
    from PIL import Image, ImageDraw, ImageFont
except ImportError:
    sys.exit("Install Pillow:  pip install Pillow")

DB_DEFAULT = Path.home() / ".hamdat" / "hamdat.db"

# TTF fonts searched in order.  Bold weights preferred; slashed-zero fonts first.
# Install fonts-hack for a slashed zero:  sudo apt install fonts-hack
# Layout proportions (all sizes in inches) per label stock.
# 4x6: physical 4"×6" portrait on the roll; rendered landscape, rotated 90° CW for ZPL.
# 4x2: physical 4"×2"; rendered as-is, no rotation needed.
_LABEL_CFG = {
    "4x6": dict(
        lw_in=6,   lh_in=4,   rotate=True,
        mt=0.17,   mb=0.17,   ms=0.20,  gap=0.07, div=4,
        banner_h=0.24, name_h=0.37, loc_h=0.31, note_h=0.27, call_pad=0.05,
    ),
    "4x2": dict(
        lw_in=4,   lh_in=2,   rotate=False,
        mt=0.13,   mb=0.09,   ms=0.12,  gap=0.04, div=3,
        banner_h=0.15, name_h=0.20, loc_h=0.17, note_h=0.14, call_pad=0.03,
    ),
}

_FONT_CANDIDATES = [
    "/usr/share/fonts/truetype/hack/Hack-Bold.ttf",
    "/usr/share/fonts/truetype/hack/Hack-Regular.ttf",
    "/usr/share/fonts/truetype/inconsolata/Inconsolata-Bold.ttf",
    "/usr/share/fonts/truetype/inconsolata/Inconsolata-Regular.ttf",
    "/usr/share/fonts/truetype/dejavu/DejaVuSansMono-Bold.ttf",
    "/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf",
    "/usr/share/fonts/truetype/liberation/LiberationMono-Bold.ttf",
    "/usr/share/fonts/truetype/liberation/LiberationMono-Regular.ttf",
    "/usr/share/fonts/truetype/noto/NotoMono-Regular.ttf",
    "/usr/share/fonts/truetype/ubuntu/UbuntuMono-B.ttf",
]


def find_font(custom_path=None):
    """Return a path to a usable TTF font, or exit with a helpful message."""
    if custom_path:
        if not Path(custom_path).exists():
            sys.exit(f"Font not found: {custom_path}")
        return custom_path
    for path in _FONT_CANDIDATES:
        if Path(path).exists():
            return path
    sys.exit(
        "No suitable font found. Install one with:\n"
        "  sudo apt install fonts-hack        (recommended — has slashed zero)\n"
        "  sudo apt install fonts-dejavu-core (fallback)\n"
        "Or specify a font with --font /path/to/font.ttf"
    )


def lookup_callsign(callsign, db_path):
    """Return (name, city, state) from hamdat DB, or (None, None, None)."""
    db = Path(db_path)
    if not db.exists():
        return None, None, None

    conn = sqlite3.connect(db)
    conn.row_factory = sqlite3.Row
    row = conn.execute(
        """
        SELECT e.first_name, e.mi, e.last_name, e.entity_name, e.city, e.state
          FROM license_header h
          JOIN entity e ON e.unique_system_identifier = h.unique_system_identifier
         WHERE h.call_sign = ?
           AND (e.entity_type = 'L' OR e.entity_type = '')
         ORDER BY h.rowid DESC,
                  CASE WHEN e.entity_type = 'L' THEN 0 ELSE 1 END
         LIMIT 1
        """,
        (callsign.strip().upper(),),
    ).fetchone()
    conn.close()

    if not row:
        return None, None, None

    parts = [row["first_name"] or "", row["mi"] or "", row["last_name"] or ""]
    name = " ".join(p.strip().title() for p in parts if p and p.strip())
    if not name:
        name = (row["entity_name"] or "").strip().title()

    city  = (row["city"]  or "").strip().title()
    state = (row["state"] or "").strip().upper()
    return name or None, city or None, state or None


def make_label_image(callsign, name, location, banner=None, note=None,
                     dpi=203, font_path=None, label="4x6"):
    """Render the complete label as a PIL RGB Image in reading orientation.

    Call label_image_to_zpl() to rotate (if needed) and convert for printing.
    """
    cfg = _LABEL_CFG[label]
    lw  = round(cfg["lw_in"]   * dpi)
    lh  = round(cfg["lh_in"]   * dpi)
    mt  = round(cfg["mt"]      * dpi)
    mb  = round(cfg["mb"]      * dpi)
    ms  = round(cfg["ms"]      * dpi)
    div = cfg["div"]
    gap = round(cfg["gap"]     * dpi)
    name_h   = round(cfg["name_h"]   * dpi)
    loc_h    = round(cfg["loc_h"]    * dpi)
    note_h   = round(cfg["note_h"]   * dpi)
    call_pad = round(cfg["call_pad"] * dpi)

    img  = Image.new("RGB", (lw, lh), "white")
    draw = ImageDraw.Draw(img)
    draw.rectangle([10, 10, lw - 11, lh - 11], outline="black", width=3)

    def fit_font(text, max_h, max_w=None):
        """Binary-search for the largest point size fitting max_w × max_h."""
        if max_w is None:
            max_w = lw - 2 * ms
        lo, hi = 8, max_h
        best = lo
        while lo <= hi:
            mid = (lo + hi) // 2
            f   = ImageFont.truetype(font_path, mid)
            bb  = f.getbbox(text)
            if (bb[2] - bb[0]) <= max_w and (bb[3] - bb[1]) <= max_h:
                best = mid
                lo   = mid + 1
            else:
                hi = mid - 1
        return ImageFont.truetype(font_path, best)

    def draw_centered(text, font, y):
        """Draw text horizontally centered at y. Returns rendered text height."""
        bb = font.getbbox(text)
        x  = (lw - (bb[2] - bb[0])) // 2 - bb[0]
        draw.text((x, y - bb[1]), text, fill="black", font=font)
        return bb[3] - bb[1]

    def draw_divider(y):
        draw.rectangle([ms, y, lw - ms, y + div - 1], fill="black")

    y = mt

    # ── Banner (optional) ─────────────────────────────────────────────────────
    if banner:
        bh = round(cfg["banner_h"] * dpi)
        draw_centered(banner, fit_font(banner, bh), y)
        y += bh + gap
        draw_divider(y)
        y += div + gap

    # ── Callsign ──────────────────────────────────────────────────────────────
    reserved = (
        gap + div + gap
        + name_h + gap
        + (loc_h if location else 0)
        + (note_h + gap if note else 0)
        + mb
    )
    call_budget = lh - y - reserved
    f  = fit_font(callsign, call_budget - call_pad * 2,
                  max_w=lw - 2 * ms - call_pad * 2)
    th = draw_centered(callsign, f, y + call_pad)
    y += th + call_pad * 2 + gap

    # ── Divider ───────────────────────────────────────────────────────────────
    draw_divider(y)
    y += div + gap

    # ── Name ──────────────────────────────────────────────────────────────────
    draw_centered(name, fit_font(name, name_h), y)
    y += name_h + gap

    # ── Location ──────────────────────────────────────────────────────────────
    if location:
        draw_centered(location, fit_font(location, loc_h), y)

    # ── Note (pinned to bottom) ───────────────────────────────────────────────
    if note:
        note_y = lh - mb - note_h
        draw_centered(note, fit_font(note, note_h), note_y)

    return img


def label_image_to_zpl(img, dpi=203, label="4x6"):
    """Convert a PIL label Image to a ZPL string ready to send to the printer."""
    cfg = _LABEL_CFG[label]
    out = img.rotate(-90, expand=True) if cfg["rotate"] else img
    out = out.convert("1", dither=Image.Dither.NONE)
    phys_w = round((cfg["lh_in"] if cfg["rotate"] else cfg["lw_in"]) * dpi)
    phys_h = round((cfg["lw_in"] if cfg["rotate"] else cfg["lh_in"]) * dpi)
    rw, _  = out.size
    bytes_per_row = (rw + 7) // 8
    raw      = out.tobytes()
    inverted = bytes(b ^ 0xFF for b in raw)   # PIL white=1 → ZPL 0 (no ink)
    total    = len(inverted)
    hex_data = inverted.hex().upper()
    return "\n".join([
        "^XA",
        f"^PW{phys_w}",
        f"^LL{phys_h}",
        "^LH0,0",
        f"^FO0,0^GFA,{total},{total},{bytes_per_row},{hex_data}^FS",
        "^XZ",
    ])


def _send_to_printer(zpl, device_path):
    """Write ZPL bytes to a printer device. Raises OSError / PermissionError."""
    with open(device_path, "wb") as f:
        f.write(zpl.encode())


def run_gui(args):
    """Launch the interactive tkinter GUI."""
    try:
        import tkinter as tk
        from tkinter import messagebox
        from PIL import ImageTk
    except ImportError as exc:
        sys.exit(f"GUI requires tkinter (usually bundled with Python): {exc}")

    font_path      = find_font(args.font)
    dpi            = args.dpi
    label          = args.label
    printer_device = args.printer or "/dev/usb/lp0"

    root = tk.Tk()
    root.title("hamtag — Ham Badge Printer")
    root.resizable(False, False)

    call_var     = tk.StringVar(value=(args.call or "").upper())
    name_var     = tk.StringVar(value=args.name or "")
    location_var = tk.StringVar(value=args.location or "")
    banner_var   = tk.StringVar(value=args.banner or "")
    note_var     = tk.StringVar(value=args.note or "")
    status_var   = tk.StringVar(value="Enter a callsign and press Enter to look up.")

    # Capture initial CLI values so Default button can restore them
    default_banner = args.banner or ""
    default_note   = args.note   or ""

    # ── Layout ────────────────────────────────────────────────────────────────
    outer = tk.Frame(root, padx=10, pady=10)
    outer.pack()

    form_frame = tk.LabelFrame(outer, text="Badge Details", padx=10, pady=10)
    form_frame.grid(row=0, column=0, sticky="nsew", padx=(0, 10))

    prev_frame = tk.LabelFrame(outer, text="Preview", padx=4, pady=4)
    prev_frame.grid(row=0, column=1, sticky="nsew")

    # Scale preview to fit a fixed 609×406 box, preserving label aspect ratio.
    cfg  = _LABEL_CFG[label]
    _scl = min(round(6 * 203 * 0.5) / (cfg["lw_in"] * dpi),
               round(4 * 203 * 0.5) / (cfg["lh_in"] * dpi))
    PW   = round(cfg["lw_in"] * dpi * _scl)
    PH   = round(cfg["lh_in"] * dpi * _scl)
    prev_lbl = tk.Label(prev_frame, width=PW, height=PH, bg="gray80")
    prev_lbl.pack()

    fields_def = [
        ("Banner",   banner_var),
        ("Callsign", call_var),
        ("Name",     name_var),
        ("Location", location_var),
        ("Note",     note_var),
    ]
    entries = {}
    for i, (lbl, var) in enumerate(fields_def):
        tk.Label(form_frame, text=lbl + ":", anchor="e", width=9).grid(
            row=i, column=0, sticky="e", pady=4)
        e = tk.Entry(form_frame, textvariable=var, width=28,
                     font=("TkDefaultFont", 11))
        e.grid(row=i, column=1, sticky="ew", pady=4)
        entries[lbl] = e

    btn_row = tk.Frame(form_frame)
    btn_row.grid(row=len(fields_def), column=0, columnspan=2, pady=(12, 0))

    lookup_btn  = tk.Button(btn_row, text="Look Up",  width=12)
    lookup_btn.pack(side="left", padx=6)
    print_btn   = tk.Button(btn_row, text="Print It!", width=12, state="disabled")
    print_btn.pack(side="left", padx=6)
    default_btn = tk.Button(btn_row, text="Default",  width=10)
    default_btn.pack(side="left", padx=6)

    tk.Label(root, textvariable=status_var, anchor="w",
             relief="sunken", bd=1, padx=6).pack(fill="x", side="bottom")

    # ── Preview ───────────────────────────────────────────────────────────────
    _job   = [None]
    _photo = [None]   # keep reference so GC doesn't collect it

    def refresh_preview():
        cs  = call_var.get().strip().upper() or "CALL"
        nm  = name_var.get().strip() or cs
        loc = location_var.get().strip() or None
        ban = banner_var.get().strip() or None
        nt  = note_var.get().strip() or None
        try:
            pil = make_label_image(cs, nm, loc, ban, nt, dpi, font_path, label)
            pil = pil.resize((PW, PH), Image.LANCZOS)
            _photo[0] = ImageTk.PhotoImage(pil)
            prev_lbl.configure(image=_photo[0])
        except Exception as exc:
            status_var.set(f"Preview error: {exc}")

    def schedule_preview(*_):
        if _job[0]:
            root.after_cancel(_job[0])
        _job[0] = root.after(300, refresh_preview)

    for _, var in fields_def:
        var.trace_add("write", schedule_preview)

    # ── Lookup ────────────────────────────────────────────────────────────────
    _lookup_found = [False]

    def _print_status():
        cs = call_var.get().strip().upper()
        focused = root.focus_get()
        if _lookup_found[0]:
            if focused == print_btn:
                status_var.set(f"{cs} Found in HAMDAT — press Enter to print.")
            else:
                status_var.set(f"{cs} Found in HAMDAT — click Print It! to print.")
        else:
            status_var.set(f"{cs} NOT Found in HAMDAT — fill in manually.")

    def do_lookup(*_):
        cs = call_var.get().strip().upper()
        if not cs:
            status_var.set("Enter a callsign first.")
            entries["Callsign"].focus_set()
            return
        call_var.set(cs)
        name_var.set("")
        location_var.set("")
        db_name, db_city, db_state = lookup_callsign(cs, args.db)
        if db_name:
            name_var.set(db_name)
        if db_city or db_state:
            location_var.set(", ".join(p for p in [db_city, db_state] if p))
        _lookup_found[0] = any([db_name, db_city, db_state])
        _print_status()
        print_btn.configure(state="normal")
        print_btn.focus_set()

    # ── Print ─────────────────────────────────────────────────────────────────
    def do_print(*_):
        cs  = call_var.get().strip().upper() or name_var.get().strip()
        nm  = name_var.get().strip() or cs
        loc = location_var.get().strip() or None
        ban = banner_var.get().strip() or None
        nt  = note_var.get().strip() or None
        if not cs:
            status_var.set("Nothing to print.")
            return
        try:
            pil = make_label_image(cs, nm, loc, ban, nt, dpi, font_path, label)
            zpl = label_image_to_zpl(pil, dpi, label)
        except Exception as exc:
            status_var.set(f"Render error: {exc}")
            return
        device = Path(printer_device)
        if not device.exists():
            messagebox.showerror(
                "Printer not found",
                f"Device not found: {printer_device}\n"
                "Is the printer connected and powered on?",
            )
            return
        try:
            _send_to_printer(zpl, device)
        except PermissionError:
            messagebox.showerror(
                "Permission denied",
                f"Cannot write to {printer_device}\n"
                f"Fix with:  sudo usermod -aG lp {os.getlogin()}",
            )
            return
        except OSError as exc:
            messagebox.showerror("Print error", str(exc))
            return
        status_var.set(f"Printed {cs}  ✓")
        # Reset for next badge — keep banner and note (they're event-level constants)
        call_var.set("")
        name_var.set("")
        location_var.set("")
        print_btn.configure(state="disabled")
        entries["Callsign"].focus_set()

    # ── Default ───────────────────────────────────────────────────────────────
    def do_default(*_):
        call_var.set("")
        name_var.set("")
        location_var.set("")
        banner_var.set(default_banner)
        note_var.set(default_note)
        print_btn.configure(state="disabled")
        status_var.set("Restored defaults — enter a callsign.")
        entries["Callsign"].focus_set()

    default_btn.configure(command=do_default)

    # ── Key bindings ──────────────────────────────────────────────────────────
    def on_callsign_return(e):
        do_lookup()
        return "break"

    def on_print_return(e):
        do_print()
        return "break"

    entries["Callsign"].bind("<Return>", on_callsign_return)
    print_btn.bind("<Return>", on_print_return)

    print_btn.bind("<FocusIn>",  lambda e: _print_status() if print_btn["state"] == "normal" else None)
    print_btn.bind("<FocusOut>", lambda e: _print_status() if print_btn["state"] == "normal" else None)
    lookup_btn.configure(command=do_lookup)
    print_btn.configure(command=do_print)

    root.bind("<Escape>", do_default)

    entries["Callsign"].focus_set()
    # Trigger an initial lookup if --call was supplied on the command line
    if args.call:
        do_lookup()
    else:
        refresh_preview()

    root.mainloop()


def main():
    parser = argparse.ArgumentParser(
        description=(
            "Generate a ZPL name badge label for a Zebra thermal printer. "
            "Produces landscape output on standard 4\"×6\" label stock."
        )
    )
    parser.add_argument(
        "--call", metavar="CALLSIGN",
        help="HAM callsign to look up in the hamdat database",
    )
    parser.add_argument(
        "--name", metavar="NAME",
        help="Operator name — overrides the database value",
    )
    parser.add_argument(
        "--location", metavar="TEXT",
        help="Location line, e.g. 'Hoboken, NJ' — overrides the database value",
    )
    parser.add_argument(
        "--banner", metavar="TEXT",
        help="Banner text at the top of the badge, e.g. 'HAMFEST VOLUNTEER'",
    )
    parser.add_argument(
        "--note", metavar="TEXT",
        help="Small text pinned to the bottom of the badge",
    )
    parser.add_argument(
        "--font", metavar="FILE",
        help="TrueType font for all text (auto-detected if omitted; "
             "install fonts-hack for a slashed zero)",
    )
    parser.add_argument(
        "--db", metavar="PATH", default=str(DB_DEFAULT),
        help=f"hamdat SQLite database path (default: {DB_DEFAULT})",
    )
    parser.add_argument(
        "--dpi", type=int, choices=[203, 300], default=203,
        help="Printer DPI — 203 (default) or 300",
    )
    parser.add_argument(
        "--label", choices=["4x6", "4x2"], default="4x6",
        help="Label stock — 4x6 landscape badge (default) or 4x2 portrait",
    )
    parser.add_argument(
        "--output", metavar="FILE",
        help="Write ZPL to FILE instead of stdout",
    )
    parser.add_argument(
        "--printer", metavar="DEVICE", nargs="?", const="/dev/usb/lp0",
        help="Send ZPL directly to a USB Zebra printer (default: /dev/usb/lp0)",
    )
    parser.add_argument(
        "--gui", action="store_true",
        help="Launch interactive GUI (other flags pre-fill the form)",
    )
    args = parser.parse_args()

    # ── GUI mode ──────────────────────────────────────────────────────────────
    if args.gui:
        run_gui(args)
        return

    # ── CLI mode ──────────────────────────────────────────────────────────────
    if not args.call and not args.name:
        parser.error("--call and/or --name is required (or use --gui)")

    callsign = (args.call or "").upper().strip()
    name     = args.name
    location = args.location

    if callsign:
        db_name, db_city, db_state = lookup_callsign(callsign, args.db)
        if not name and db_name:
            name = db_name
        if not location and (db_city or db_state):
            location = ", ".join(p for p in [db_city, db_state] if p)
        if not any([db_name, db_city, db_state]):
            print(f"Warning: {callsign} not found in database", file=sys.stderr)

    if not name:
        name = callsign or "(unknown)"

    display_call = callsign if callsign else name
    font_path    = find_font(args.font)

    img = make_label_image(
        display_call, name, location,
        banner=args.banner,
        note=args.note,
        dpi=args.dpi,
        font_path=font_path,
        label=args.label,
    )
    zpl = label_image_to_zpl(img, args.dpi, args.label)

    if args.output:
        Path(args.output).write_text(zpl)
        print(f"ZPL written to {args.output}", file=sys.stderr)

    if args.printer:
        device = Path(args.printer)
        if not device.exists():
            sys.exit(
                f"Printer device not found: {args.printer}\n"
                "Check that the printer is connected and powered on.\n"
                "You may need: sudo chmod a+rw /dev/usb/lp0"
            )
        try:
            _send_to_printer(zpl, device)
            print(f"Sent to {device}", file=sys.stderr)
        except PermissionError:
            sys.exit(
                f"Permission denied: {device}\n"
                f"Fix with:  sudo usermod -aG lp {os.getlogin()}\n"
                "Then log out and back in, or run:  sudo chmod a+rw /dev/usb/lp0"
            )
        except OSError as exc:
            sys.exit(f"Error sending to printer: {exc}")

    if not args.output and not args.printer:
        print(zpl)


if __name__ == "__main__":
    main()
